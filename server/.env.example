# Server
PORT=4000
NODE_ENV=development

# PostgreSQL (Өөрийн холболтын мэдээллээр солино уу)
DATABASE_URL=postgresql://postgres:password@localhost:5432/auraskin_db

# Session
SESSION_SECRET=aura-skin-local-development-secret-key-32-chars-long

# CORS — Next.js dev URL
CORS_ORIGIN=http://localhost:3000

# Uploads directory
UPLOAD_DIR=uploads
