# Server
PORT=4000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/auraskin_db

# Session — change this to a long random string in production
SESSION_SECRET=change-this-to-a-long-random-secret-at-least-32-chars

# CORS — Next.js dev URL
CORS_ORIGIN=http://localhost:3000

# Uploads directory (relative to server/)
UPLOAD_DIR=uploads
